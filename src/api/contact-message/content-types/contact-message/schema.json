    "firstName": {
      "type": "string",
      "required": true,
      "maxLength": 120
    },
    "lastName": {
      "type": "string",
      "required": true,
      "maxLength": 120
    },
    "industryType": {
      "type": "string",
      "required": true,
      "maxLength": 200
    },
    "businessType": {
      "type": "string",
      "required": true,
      "maxLength": 200
    },
    "organization": {
      "type": "string",
      "required": true,
