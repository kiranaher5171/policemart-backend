# SQLite (default-friendly local dev):
# DATABASE_CLIENT=sqlite
#
# MySQL via Docker in this repo (port 3307 so 3306 can stay XAMPP/etc.): docker compose up -d
# DATABASE_CLIENT=mysql
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=3307
# DATABASE_NAME=defaultdb
# DATABASE_USERNAME=strapi
# DATABASE_PASSWORD=strapi
# DATABASE_SSL=false

HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# --- Production uploads (Render): use S3-compatible storage; local disk is wiped on redeploy ---
# AWS_S3_UPLOAD_ENABLED=true
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_BUCKET=
# Optional public URL / CDN for saved file URLs (see Strapi S3 docs):
# AWS_S3_PUBLIC_URL=https://your-cdn.example.com
# AWS_S3_ROOT_PATH=
# MinIO / R2 / some hosts need endpoint + path style:
# AWS_S3_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
# AWS_S3_FORCE_PATH_STYLE=true
# Cloudflare R2: set AWS_S3_DISABLE_ACL=true (R2 has no object ACLs)
# Admin CSP: allow Media Library previews from your bucket/CDN (comma-separated hostnames, no https://):
# AWS_S3_CSP_MEDIA_HOST=your-bucket.s3.us-east-1.amazonaws.com
